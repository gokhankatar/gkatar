{
  "name": "gkatar",
  "version": "1.2.1",
  "description": "Windows için Türkçe terminal CLI — sistem yönetimi ve geliştirici araç kutusu",
  "author": "Gökhan Katar <https://github.com/gokhankatar>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gokhankatar/gkatar.git"
  },
  "homepage": "https://github.com/gokhankatar/gkatar#readme",
  "bugs": {
    "url": "https://github.com/gokhankatar/gkatar/issues"
  },
  "type": "module",
  "bin": {
    "gkatar": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "release": "npm version patch --no-git-tag-version && npm publish",
    "release:minor": "npm version minor --no-git-tag-version && npm publish",
    "release:major": "npm version major --no-git-tag-version && npm publish"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cli",
    "windows",
    "system",
    "powershell",
    "devtools",
    "gkatar",
    "turkish",
    "türkçe",
    "terminal",
    "system-tools"
  ],
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.20.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.8.2"
  }
}
